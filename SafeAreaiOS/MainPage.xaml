<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SafeAreaiOS.MainPage"
             NavigationPage.HasNavigationBar="false"
             BackgroundColor="Red">

    <Grid x:Name="RootGrid" BackgroundColor="Blue">
        <Label Text="TOP NOTCH TEST" BackgroundColor="Yellow" TextColor="Black" 
               VerticalOptions="Start" HorizontalOptions="Center" FontAttributes="Bold" />
               
        <VerticalStackLayout Spacing="15" Padding="20" VerticalOptions="Center">
            
            <Label Text="iOS VC Hierarchy Diagnostic" 
                   FontSize="24" HorizontalOptions="Center" TextColor="White" />

            <Button x:Name="ToggleInsetsHackBtn" Text="Toggle Insets Hack" Clicked="OnToggleInsetsHack" />
            <Button x:Name="DumpVCBtn" Text="Dump VC Hierarchy" Clicked="OnDumpVCHierarchy" />
            
            <Label x:Name="StatusLabel" TextColor="White" HorizontalOptions="Start" FontSize="11" />

        </VerticalStackLayout>
    </Grid>

</ContentPage>
