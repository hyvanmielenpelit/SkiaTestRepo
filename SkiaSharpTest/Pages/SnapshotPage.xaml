<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SkiaSharpTest.Controls"
             x:Class="SkiaSharpTest.Pages.SnapshotPage"
             Title="SnapshotPage"
             BackgroundColor="Transparent">
    
    <Grid>
        <controls:BackgroundView x:Name="bkgView" />
        
        <Grid Margin="20" RowDefinitions="Auto, *, Auto">
            <StackLayout Grid.Row="0">
                <Label Text="Snapshots" FontFamily="Diablo" FontSize="32" TextColor="White" HorizontalOptions="Center" />
                <Label x:Name="lblSubtitle" Text="Loading..." FontFamily="Diablo" FontSize="18" TextColor="White" HorizontalOptions="Center" />
                <Label x:Name="lblTime" Text="" FontSize="16" TextColor="Yellow" HorizontalOptions="Center" />
            </StackLayout>

            <ScrollView Grid.Row="1" Margin="0, 20, 0, 20">
                <StackLayout x:Name="SnapshotLayout" Spacing="10" />
            </ScrollView>

            <controls:CustomImageButton Grid.Row="2" x:Name="CloseButton" Text="Close" Clicked="CloseButton_Clicked" HeightRequest="60" WidthRequest="250" FontFamily="Diablo" FontSize="19" HorizontalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>
